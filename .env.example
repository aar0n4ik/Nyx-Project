# ============================================================
#  OFFSIDE — environment variables (add these in Vercel > Settings > Environment Variables)
#  NONE of these are required for the offline demo to run. They light up the online extras.
# ============================================================

# --- AI trade narrative (Groq, free) --------------------------------
# Get a free key at https://console.groq.com  ->  API Keys
GROQ_API_KEY=

# --- TxLINE match-data feed (REQUIRED by the hackathon, free World Cup tier) ---
# devnet host is free. Get TXLINE_JWT from: curl -X POST https://txline-dev.txodds.com/auth/guest/start
# TXLINE_API_TOKEN comes from the activate step (see README + docs/06-txline-free-api.md)
TXLINE_NET=devnet
TXLINE_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=

# --- Exchange execution (FUTURE — leave blank; the demo never calls it) ---
BYBIT_BASE=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
